# Agent tooling secrets — copy to .env.agent.local and fill in values.
# This file is tracked by git. .env.agent.local is gitignored — never commit it.
#
# These variables are NOT loaded by Next.js. They are read directly by Claude
# when performing operational tasks (deployment checks, external API calls).

# Vercel API token — generate at: vercel.com → Account Settings → Tokens
VERCEL_TOKEN=
